tri = Triangulation3.fromSig('cPcbbbiht') # figure eight knot complement
data = IsoSigData1_3(tri.component(0))
data.fillFrom(tri.simplex(0), Perm4())
print(data.facetTypes())
print(data.adjacentSimplices())
print(data.adjacentGluings())
print(data.locks())
print(IsoSigPrintable.encode(data))
print()

link = Link.fromSig('eabcdbadcvbZa') # figure eight knot
data = LinkSigData(link, BoolSet(True, True), True, BoolSet(True, True))
print(data.size())
print([(s.crossing, s.strand, s.sign) for s in data.sequence()])
print(LinkSigGen1.encode(data))
print(LinkSigGen2.encode(data))
print(LinkSigBinary.encode(data))
print(link.knotSig())
print(link.neoSig())
print(link.neoSig_binary())
print(link.sig(LinkSigGen1))
print(link.sig(LinkSigGen2))
print(link.sig(LinkSigBinary))
print(Link.fromSig(link.knotSig()))
print(Link.fromSig(link.neoSig()))
print(Link.fromSig(link.neoSig_binary()))
print(LinkSigBinary.asString(link.neoSig_binary()))
print()

enc = PackedSigEncoder()
tmp = enc.encodeSize(1000)
print(enc.bytes())
dec = PackedSigDecoder(enc.bytes())
print(dec.done())
print(dec.decodeSize())
print(dec.done())
print()
