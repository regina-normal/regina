# ---------- Testing IsoSigData ----------

tri = Triangulation3.fromSig('cPcbbbiht') # figure eight knot complement
data = IsoSigData1_3(tri.component(0))
data.fillFrom(tri.simplex(0), Perm4())
print(data.facetTypes())
print(data.adjacentSimplices())
print(data.adjacentGluings())
print(data.locks())
print(IsoSigPrintable.encode(data))
print()

# ---------- Testing isomorphism signatures of triangulations ----------

tri = Example3.weeks()
tri.simplex(0).lock()
print(tri.sig(1))
print(tri.isoSig())
print(tri.isoSig(IsoSigPrintableLockFree))
print(tri.isoSig(IsoSigPrintable, IsoSigClassic3))
print(tri.isoSig(IsoSigPrintable, IsoSigEdgeDegrees3))
print(tri.sig(2))
print(tri.neoSig())
print(tri.neoSig(False, IsoSigPrintableLockFree))
print(tri.neoSig(False, IsoSigPrintable, IsoSigClassic3))
print(tri.neoSig(False, IsoSigPrintable, IsoSigEdgeDegrees3))
print(tri.neoSig(False, IsoSigBinary))
print(Triangulation3.fromSig(tri.isoSig()))
print(Triangulation3.fromSig(tri.neoSig(False, IsoSigBinary)))
print(IsoSigBinary.asString(tri.neoSig(False, IsoSigBinary), 3))
print()

# ---------- Testing oriented vs non-oriented signatures ----------

tri = Example3.lens(3, 1)
try:
	print(tri.neoSig(True))
except:
	print('Caught exception')

tri.orient()
alt = Triangulation3(tri)
alt.reflect()
print(tri.neoSig())
print(alt.neoSig())
print(tri.neoSig(True))
print(alt.neoSig(True))
print()

# ---------- Testing knot/link signatures ----------

link = Link.fromSig('eabcdbadcvbZa') # figure eight knot
data = LinkSigData(link, BoolSet(True, True), True, BoolSet(True, True))
print(data.size())
print([(s.crossing, s.strand, s.sign) for s in data.sequence()])
print(LinkSigGen1.encode(data))
print(LinkSigGen2.encode(data))
print(LinkSigBinary.encode(data))
print(link.knotSig())
print(link.neoSig())
print(link.neoSig_binary())
print(link.sig(LinkSigGen1))
print(link.sig(LinkSigGen2))
print(link.sig(LinkSigBinary))
print(Link.fromSig(link.knotSig()))
print(Link.fromSig(link.neoSig()))
print(Link.fromSig(link.neoSig_binary()))
print(LinkSigBinary.asString(link.neoSig_binary()))
print()

# ---------- Testing "raw" encoders/decoders ----------

enc = PackedByteEncoder()
tmp = enc.encodeSize(1000)
print(enc.bytes())
dec = PackedByteDecoder(enc.bytes())
print(dec.done())
print(dec.decodeSize())
print(dec.done())
print()

enc = BitEncoder()
enc.encodeInt(3, 0x0002)
enc.encodeInt(14, 0x3576)
print(enc.bytes())
try:
	enc.encodeBit(True)
except:
	print('Caught exception')

try:
	enc = BitEncoder()
	enc.encodeBits(3, 0x0002)
	enc.encodeBits(14, 0x4576)
except:
	print('Caught exception')

print()

enc = Base64BitEncoder()
enc.encodeInt(3, 0x0002)
enc.encodeInt(14, 0x3576)
print(enc.str())
try:
	enc.encodeBit(True)
except:
	print('Caught exception')

try:
	enc = Base64BitEncoder()
	enc.encodeBits(3, 0x0002)
	enc.encodeBits(14, 0x4576)
except:
	print('Caught exception')

print()

