import sys
if (len(sys.argv) > 1):
    testpath = sys.argv[1]
else:
    testpath = '.'

def testLink():
    print('Links')
    for gen in [ 'g1', 'g2' ]:
        ans = readSigList(0, testpath + '/sigs-' + gen + '-links.txt')
        for c in ans.children():
            if c.type() == PacketType.Text:
                print('Errors:\n' + c.text())
            else:
                print('->', c.knotSig())
    print()

def testTri(dim):
    print('Dimension:', dim)
    for gen in [ 'g1', 'g2' ]:
        ans = readSigList(dim, testpath + '/sigs-' + gen + '-dim' + str(dim) + '.txt')
        for c in ans.children():
            if c.type() == PacketType.Text:
                print('Errors:\n' + c.text())
            else:
                print('->', c.neoSig())
    print()

testLink()
for dim in range(2, 9):
    testTri(dim)

print('Non-existent file:')
c = readSigList(3, '/no/such/file')
print(c)
print()

print('Bad dimension:')
try:
    c = readSigList(1, testpath + '/sigs-links.txt')
except InvalidArgument:
    print('Caught exception')
print()

