except SnapPeaIsNull:
    print('Caught SnapPeaIsNull')

try:
    throwSnapshotWriteError()
    print('ERROR: Did not throw SnapshotWriteError')
except SnapshotWriteError:
    print('Caught SnapshotWriteError')

