def throwFailedPrecondition():
    t = ExampleSnapPea.whiteheadLink()
    print(t.filledAll()) # should throw

def throwInvalidArgument():
    t = Example3.poincare()
    print(t.faces(2).size()) # should print
    print(t.faces(3).size()) # should throw

def throwInvalidArgumentV2():
    t = Example3.poincare()
    print(t.faces(-1).size()) # should throw

def throwNotImplemented():
    s = SFSpace()
    print(s.construct().homology()) # should print
    s.addPuncture()
    print(s.construct()) # should throw

def throwFileError():
    print(SpatialLink.fromKnotPlot('/no/such/file')) # should throw

def throwNoSolution():
    print(Example3.figureEight().generalAngleStructure()) # should print
    print(Example3.poincare().generalAngleStructure()) # should throw

def throwUnsolvedCase():
    print(Rational(1,2).doubleApprox()) # should print
    print(Rational(1,0).doubleApprox()) # should throw

def throwLockViolation():
    t = Example3.poincare()
    t.simplex(0).lock()
    t.removeSimplex(t.simplex(1)) # should not throw
    print(t.sig()) # should print
    t.removeSimplex(t.simplex(0)) # should throw
    print(t.sig()) # should never reach

def throwIntegerOverflow():
    print(Integer(2**15).safeValue()) # should print
    print(Integer(2**127).safeValue()) # should throw

def throwDivisionByZero():
    i = Integer(4)
    print(i / 2) # should print
    print(i / 0) # should throw

def throwSnapPeaIsNull():
    t = ExampleSnapPea.whiteheadLink()
    dummy = t.fill(1,2,0)
    dummy = t.fill(3,4,1)
    print(t.filledAll().homology()) # should print
    dummy = t.pachner(t.triangle(0))
    print(t.filledAll()) # should throw

def throwSnapshotWriteError():
    t = Example3.poincare()
    s = NormalSurfaces(t, NormalCoords.Standard)
    t = None
    print(s) # should print
    t = s.triangulation()
    print(t.isReadOnlySnapshot()) # should be true
    # TODO: subdivide(), due to a swap() in its internal implementation,
    # actually throws a SnapshotWriteError from a triangulation destructor.
    # This is *bad*, and moreover results in an exception that Python cannot
    # catch.
    # t.subdivide()
    t.pachner(t.triangle(0)) # should throw

######################################################################

try:
    throwFailedPrecondition()
    print('ERROR: Did not throw FailedPrecondition')
except FailedPrecondition:
    print('Caught FailedPrecondition')

try:
    throwInvalidArgument()
    print('ERROR: Did not throw InvalidArgument')
except InvalidArgument:
    print('Caught InvalidArgument')

try:
    throwInvalidArgumentV2()
    print('ERROR: Did not throw InvalidArgument')
except InvalidArgument:
    print('Caught InvalidArgument')

# TODO: Test InvalidInput (can we even get this in python?)

try:
    throwNotImplemented()
    print('ERROR: Did not throw NotImplemented')
except NotImplemented:
    print('Caught NotImplemented')

try:
    throwFileError()
    print('ERROR: Did not throw FileError')
except FileError:
    print('Caught FileError')

try:
    throwNoSolution()
    print('ERROR: Did not throw NoSolution')
except NoSolution:
    print('Caught NoSolution')

try:
    throwUnsolvedCase()
    print('ERROR: Did not throw UnsolvedCase')
except UnsolvedCase:
    print('Caught UnsolvedCase')

try:
    throwLockViolation()
    print('ERROR: Did not throw LockViolation')
except LockViolation:
    print('Caught LockViolation')

# We cannot test for ImpossibleScenario since this should be impossible to
# produce.

try:
    throwIntegerOverflow()
    print('ERROR: Did not throw IntegerOverflow')
except IntegerOverflow:
    print('Caught IntegerOverflow')

try:
    throwDivisionByZero()
    print('ERROR: Did not throw DivisionByZero')
except DivisionByZero:
    print('Caught DivisionByZero')

